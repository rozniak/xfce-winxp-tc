<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <object class="WinTCWizard97Page" id="page">
    <property name="visible">True</property>
    <property name="is-exterior-page">True</property>
    <property name="orientation">vertical</property>

    <child>
      <object class="GtkLabel">
        <property name="label">Type a name for this shortcut:</property>
        <property name="visible">True</property>
        <property name="xalign">0.0</property>

        <style>
          <class name="wintc-mb-sm" />
        </style>
      </object>
    </child>

    <child>
      <object class="GtkEntry" id="entry-name">
        <property name="visible">True</property>

        <style>
          <class name="wintc-mb-lg" />
        </style>
      </object>
    </child>

    <child>
      <object class="GtkLabel">
        <property name="label">Click Finish to create the shortcut.</property>
        <property name="visible">True</property>
        <property name="xalign">0.0</property>

        <style>
          <class name="wintc-mt-lg" />
        </style>
      </object>
    </child>
  </object>
</interface>
