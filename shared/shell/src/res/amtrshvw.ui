<?xml version="1.0" encoding="UTF-8" ?>
<interface>
  <menu id="menu">
    <section>
      <attribute name="label">Recycle Bin Tasks</attribute>

      <item>
        <attribute name="label">Empty the Recycle Bin</attribute>
        <attribute name="icon">user-trash</attribute>
        <attribute name="operation" type="i">100</attribute>
      </item>

      <item>
        <attribute name="label">Restore all items</attribute>
        <attribute name="icon">document-revert</attribute> <!-- TEMP ICON -->
      </item>
    </section>

    <section>
      <attribute name="label">Other Places</attribute>

      <item>
        <attribute name="label">Desktop</attribute>
        <attribute name="icon">user-desktop</attribute>
      </item>

      <item>
        <attribute name="label">My Documents</attribute>
        <attribute name="icon">folder-documents</attribute>
      </item>

      <item>
        <attribute name="label">My Computer</attribute>
        <attribute name="icon">computer</attribute>
      </item>

      <item>
        <attribute name="label">My Network Places</attribute>
        <attribute name="icon">network-workgroup</attribute>
      </item>
    </section>

    <section>
      <attribute name="label">Details</attribute>
      <attribute name="special">DETAILS</attribute>
    </section>
  </menu>
</interface>
